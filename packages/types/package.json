{
  "name": "@pokermap/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/generated/schema.ts",
    "./zod": "./src/zod.ts"
