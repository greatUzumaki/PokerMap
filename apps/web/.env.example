# Next.js web app config.

# Backend URL (server-side fetches). Internal/private.
API_URL=http://localhost:8080

# Backend URL used by the browser (public). Same value in local dev.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Map tile source URL. Use {z}/{x}/{y}.png template.
# Default: CARTO dark basemap (works for dev, has rate limits).
# Fallback / production-safe alternatives:
#   - https://tiles.openfreemap.org/styles/positron/{z}/{x}/{y}.png   (OpenFreeMap)
#   - https://tile.openstreetmap.org/{z}/{x}/{y}.png                  (OSM, dev only)
# OSM tile usage policy forbids high-traffic apps; swap to MapTiler/Stadia/
# Protomaps/OpenFreeMap before public launch.
NEXT_PUBLIC_MAP_TILE_URL=https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}@2x.png
NEXT_PUBLIC_MAP_ATTRIBUTION=© OpenStreetMap contributors © CARTO

# Default city bounding box (Saint Petersburg).
NEXT_PUBLIC_DEFAULT_BBOX=30.18,59.83,30.55,60.07

# Public name + contact shown in the About page.
NEXT_PUBLIC_APP_NAME=PokerMap SPb
NEXT_PUBLIC_SUPPORT_TG=https://t.me/your_support_handle
