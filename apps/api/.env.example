# Go API config. Copy to .env and fill in secrets.

# --- HTTP ---
HTTP_ADDR=:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
ENV=development

# --- Database ---
DATABASE_URL=postgres://pokermap:pokermap@localhost:5432/pokermap?sslmode=disable
DATABASE_MAX_CONNS=10

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=pokermap
MINIO_SECRET_KEY=pokermap-secret
MINIO_BUCKET=pokermap-photos
MINIO_PUBLIC_URL=http://localhost:9000

# --- Auth ---
# Get from @BotFather. PLACEHOLDER — must replace.
TELEGRAM_BOT_TOKEN=REPLACE_ME
# Generate via: openssl rand -base64 48 . PLACEHOLDER — must replace.
JWT_SECRET=REPLACE_ME_WITH_32_PLUS_RANDOM_BYTES
JWT_TTL=168h

# Comma-separated Telegram user IDs allowed to sign in as admin.
# Seeds the `admins` table on first boot; can be empty if you'll
# insert rows manually.
ADMIN_TELEGRAM_IDS=

# --- Uploads ---
UPLOAD_MAX_SIZE_BYTES=8388608
UPLOAD_URL_TTL=5m

# --- Cache (Redis) ---
# Leave empty to disable caching. Cache stores public club list/details with short TTL.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=60s
CACHE_KEY_PREFIX=pm:

# --- Superadmin (password login at /v1/auth/login) ---
# Allows admin access without Telegram. Generate via `openssl rand -base64 18`.
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=REPLACE_ME
